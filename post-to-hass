#!/usr/bin/env bash

set -u
set -e

cd $HOME/obd
source secret.sh

HASS_URL="https://hass.vanstaveren.us/api/states"

post_sensor() {
    local name="$1" friendly="$2" state="$3" extra="${4:-}"
    curl -s -X POST -H "Authorization: Bearer $hass_llac" \
       -H "Content-Type: application/json" \
       -d "{\"state\": \"$state\", \"attributes\": {\"friendly_name\": \"$friendly\"$extra}}" \
       "$HASS_URL/sensor.$name" > /dev/null
}

post_sensor "obd_battery_percent" "obd battery level" \
    "$($HOME/obd/battery.py)" ', "unit_of_measurement": "%"'

post_sensor "obd_charging_status" "obd charging status" \
    "$($HOME/obd/charging_status.py)"

post_sensor "obd_wifi_name" "obd wifi name" \
    "$(/sbin/iwconfig wlan0 | grep ESSID | cut -d\" -f2)"

post_sensor "obd_git_rev" "obd git rev" \
    "$(TZ=America/Chicago git log --date=local -1 --format=%cd) $(git rev-parse --short HEAD)"

post_sensor "obd_uptime" "obd uptime" \
    "$(uptime)"

# --- Drive summary sensors ---

latest_csv=$(ls -t $HOME/log/obd-*.csv 2>/dev/null | head -1)
if [ -n "$latest_csv" ]; then
    csv_name=$(basename "$latest_csv")
    post_sensor "obd_latest_drive" "obd latest drive" "$csv_name"

    # Drive duration: difference between first and last timestamp in the CSV
    first_ts=$(sed -n '2p' "$latest_csv" | cut -d, -f1)
    last_ts=$(tail -1 "$latest_csv" | cut -d, -f1)
    if [ -n "$first_ts" ] && [ -n "$last_ts" ]; then
        first_epoch=$(date -d "$first_ts" +%s 2>/dev/null || echo "")
        last_epoch=$(date -d "$last_ts" +%s 2>/dev/null || echo "")
        if [ -n "$first_epoch" ] && [ -n "$last_epoch" ]; then
            duration_min=$(( (last_epoch - first_epoch) / 60 ))
            post_sensor "obd_drive_duration" "obd drive duration" \
                "$duration_min" ', "unit_of_measurement": "min"'
        fi
    fi

    # Row count (data points logged)
    row_count=$(( $(wc -l < "$latest_csv") - 1 ))
    post_sensor "obd_drive_data_points" "obd drive data points" "$row_count"

    # Total drive count
    drive_count=$(ls $HOME/log/obd-*.csv 2>/dev/null | wc -l)
    post_sensor "obd_total_drives" "obd total drives" "$drive_count"
fi

# Minutes since last sync-data run (check log dir mtime or sync marker)
sync_log="$HOME/log/last-sync"
if [ -f "$sync_log" ]; then
    sync_epoch=$(stat -c %Y "$sync_log")
    now_epoch=$(date +%s)
    sync_ago_min=$(( (now_epoch - sync_epoch) / 60 ))
    post_sensor "obd_minutes_since_sync" "obd minutes since sync" \
        "$sync_ago_min" ', "unit_of_measurement": "min"'
else
    post_sensor "obd_minutes_since_sync" "obd minutes since sync" "never"
fi
