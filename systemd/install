#!/usr/bin/env bash

cd $(dirname $(realpath $0))

OBD_USER="${SUDO_USER:-$(whoami)}"
OBD_HOME=$(eval echo "~$OBD_USER")

changed=0

for unit in obd.service rtc-sync.service pisugar-poweroff.service; do
    # Substitute placeholders with actual user/home
    rendered=$(sed "s|__HOME__|$OBD_HOME|g; s|__USER__|$OBD_USER|g" "$unit")

    current=$(cat "/etc/systemd/system/$unit" 2>/dev/null)
    if [ "$rendered" != "$current" ]; then
        echo "Installing $unit..."
        echo "$rendered" | sudo tee "/etc/systemd/system/$unit" > /dev/null
        changed=1
    fi
done

if [ $changed -eq 1 ]; then
    echo "Reloading systemd"
    sudo systemctl daemon-reload
fi

echo "Enabling systemd services"
# It seems normal for these to output an error, however they do succeed:
sudo systemctl enable obd
sudo systemctl enable rtc-sync
sudo systemctl enable pisugar-poweroff
