#!/usr/bin/env python3

"""Shut down the Pi if PiSugar battery is critically low.

Intended to run from cron every minute. If the battery is below 20%
and not charging, initiates a system shutdown. The pisugar-poweroff
systemd service handles telling the MCU to cut power.
"""

import os
import subprocess
import sys
from datetime import datetime
from pisugar import PiSugar3

SHUTDOWN_THRESHOLD = 20
LOG = os.path.expanduser("~/log/battery.log")

pisugar = PiSugar3()
charging = pisugar.get_charging_status().value
pct = pisugar.get_battery_percentage().value
voltage = pisugar.get_voltage().value

ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
with open(LOG, "a") as f:
    f.write(f"{ts} battery={pct}% voltage={voltage}V charging={charging}\n")

if charging:
    sys.exit(0)

if pct >= SHUTDOWN_THRESHOLD:
    sys.exit(0)

print(f"Battery at {pct}% voltage={voltage}V (threshold {SHUTDOWN_THRESHOLD}%), shutting down")
subprocess.run(["sudo", "shutdown", "-h", "now"])
