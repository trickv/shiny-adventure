#!/usr/bin/env bash
#
# Sync logged data to the server via rsync over Tailscale.
# The Pi and the server must both be on the same Tailscale network.
# The rsync daemon runs on the server (port 8730).

# Use Tailscale IP for litecoin so this works from any network.
RSYNC_HOST="100.124.139.90"
RSYNC_PORT="8730"

export RSYNC_PASSWORD=obd

rsync -av --partial $HOME/log rsync://obd@${RSYNC_HOST}:${RSYNC_PORT}/data
touch $HOME/log/last-sync
