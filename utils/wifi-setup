#!/bin/bash
# Add a WPA-PSK WiFi network using nmcli.
# Designed to be dead simple over SSH on a phone.

set -euo pipefail

echo "=== WiFi Setup ==="
echo

read -rp "WiFi network name (SSID): " ssid

if [ -z "$ssid" ]; then
    echo "Error: SSID cannot be empty."
    exit 1
fi

read -rp "WiFi password: " password

if [ -z "$password" ]; then
    echo "Error: Password cannot be empty."
    exit 1
fi

if [ ${#password} -lt 8 ]; then
    echo "Error: WPA password must be at least 8 characters."
    exit 1
fi

echo
echo "Adding WiFi profile for '$ssid'..."

nmcli connection add \
    type wifi \
    con-name "$ssid" \
    ssid "$ssid" \
    wifi-sec.key-mgmt wpa-psk \
    wifi-sec.psk "$password" \
    connection.autoconnect yes

echo "Done! Profile '$ssid' saved. It will auto-connect when in range."
