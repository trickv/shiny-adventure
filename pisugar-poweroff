"""Tell the PiSugar MCU to cut power after the Pi finishes shutting down.

Runs as a systemd oneshot at shutdown. Sets a 10-second delay timer,
then disables the MCU's 5V output. The MCU waits for the countdown
before actually cutting power, giving the Pi time to unmount
filesystems cleanly.
"""

from pisugar import PiSugar3

pisugar = PiSugar3()
pisugar.poweroff()
print("PiSugar poweroff scheduled (10s delay)")
